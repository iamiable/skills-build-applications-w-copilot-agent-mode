# OctoFit Tracker Frontend Configuration

# Codespaces Configuration
# Set this to your Codespace name to use Codespaces URLs
# Example: VITE_CODESPACE_NAME=my-codespace-abc123
# Leave empty to use localhost (http://localhost:8000)
VITE_CODESPACE_NAME=

# Backend API Configuration
# The app will automatically construct the API base URL based on VITE_CODESPACE_NAME:
# - If set: https://${VITE_CODESPACE_NAME}-8000.app.github.dev/api
# - If empty: http://localhost:8000/api
